generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Supplier {
  id            String              @id @default(cuid())
  name          String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  accountNumber String?
  balance       Float               @default(0)
  ownerName     String?
  bankName      String?
  reports       ConsignmentReport[]
}

model Cashier {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  code      String   @unique
  updatedAt DateTime @updatedAt
}

model ConsignmentReport {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  noteNumber    String?  // No Nota
  supplierId    String
  revenue       Float
  profit80      Float
  profit20      Float
  barcode       Float
  cost          Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  kukuluban     Float?   @default(0)
  serviceCharge Float?   @default(0)
  tabungan      Float?   @default(0)
  notes         String?
  supplier      Supplier @relation(fields: [supplierId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
