generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Supplier {
  id            String              @id @default(cuid())
  name          String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  accountNumber String?
  balance       Float               @default(0)
  ownerName     String?
  bankName      String?
  reports       ConsignmentReport[]
  users         User[]
  payouts       SupplierPayout[]
}

model SupplierPayout {
  id         String   @id @default(cuid())
  amount     Float
  date       DateTime @default(now())
  notes      String?
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Cashier {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  code      String   @unique
  updatedAt DateTime @updatedAt
}

model ConsignmentReport {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  supplierId    String
  revenue       Float
  profit80      Float
  profit20      Float
  barcode       Float
  cost          Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  kukuluban     Float?   @default(0)
  serviceCharge Float?   @default(0)
  tabungan      Float?   @default(0)
  noteNumber    String?
  notes         String?
  items         Json?    @default("[]")
  supplier      Supplier @relation(fields: [supplierId], references: [id])
}

model User {
  id         String    @id @default(cuid())
  username   String    @unique
  password   String
  name       String?
  role                String    @default("ADMIN") // "ADMIN", "CASHIER", "SUPPLIER"
  supplierId          String?
  supplier            Supplier? @relation(fields: [supplierId], references: [id])
  isCredentialsChanged Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}
