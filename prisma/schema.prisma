generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Supplier {
  id               String              @id @default(cuid())
  name             String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  accountNumber    String?
  balance          Decimal             @default(0) @db.Decimal(20, 2)
  validatedBalance Decimal             @default(0) @db.Decimal(20, 2)
  ownerName        String?
  bankName         String?
  reports          ConsignmentReport[]
  users            User[]
  payouts          SupplierPayout[]
  products         Product[]
  labelPrints      LabelPrint[]
}

model LabelPrint {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  name       String
  code       String?
  qty        Int      @default(1)
  status     String   @default("PENDING") // PENDING, DONE
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SupplierPayout {
  id         String   @id @default(cuid())
  amount     Decimal  @db.Decimal(20, 2)
  date       DateTime @default(now())
  notes      String?
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Cashier {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  code      String   @unique
  updatedAt DateTime @updatedAt
}

model ConsignmentReport {
  id                  String    @id @default(cuid())
  date                DateTime  @default(now())
  supplierId          String
  revenue             Decimal   @db.Decimal(20, 2)
  profit80            Decimal   @db.Decimal(20, 2)
  profit20            Decimal   @db.Decimal(20, 2)
  barcode             Decimal   @db.Decimal(20, 2)
  cost                Decimal   @db.Decimal(20, 2)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  kukuluban           Decimal?  @default(0) @db.Decimal(20, 2)
  serviceCharge       Decimal?  @default(0) @db.Decimal(20, 2)
  tabungan            Decimal?  @default(0) @db.Decimal(20, 2)
  noteNumber          String?
  notes               String?
  deductionDate       DateTime?
  deductionNoteNumber String?
  items               Json?     @default("[]")
  isValidated         Boolean   @default(false)
  supplier            Supplier  @relation(fields: [supplierId], references: [id])
}

model User {
  id                   String    @id @default(cuid())
  username             String    @unique
  password             String
  name                 String?
  role                 String    @default("ADMIN") // "ADMIN", "CASHIER", "SUPPLIER"
  supplierId           String?
  supplier             Supplier? @relation(fields: [supplierId], references: [id])
  isCredentialsChanged Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Product {
  id         String    @id @default(cuid())
  name       String
  code       String?
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([name, supplierId])
}
