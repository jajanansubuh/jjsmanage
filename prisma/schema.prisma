generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Supplier {
  id                String              @id @default(cuid())
  name              String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  accountNumber     String?
  balance           Decimal             @default(0) @db.Decimal(20, 2)
  ownerName         String?
  bankName          String?
  validatedBalance  Decimal             @default(0) @db.Decimal(20, 2)
  reports           ConsignmentReport[]
  labelPrints       LabelPrint[]
  labelPrintHistory LabelPrintHistory[]
  products          Product[]
  payouts           SupplierPayout[]
  users             User[]
}

model LabelPrintHistory {
  id          String   @id @default(cuid())
  supplierId  String
  itemCount   Int      @default(0)
  totalQty    Int      @default(0)
  items       Json     @default("[]")
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  supplier    Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([completedAt])
  @@index([supplierId, completedAt])
}

model LabelPrint {
  id         String   @id @default(cuid())
  supplierId String
  name       String
  code       String?
  qty        Int      @default(1)
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([status])
}

model SupplierPayout {
  id         String   @id @default(cuid())
  amount     Decimal  @db.Decimal(20, 2)
  date       DateTime @default(now())
  notes      String?
  supplierId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
}

model Cashier {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  code      String   @unique
  updatedAt DateTime @updatedAt
}

model ConsignmentReport {
  id                  String    @id @default(cuid())
  date                DateTime  @default(now())
  supplierId          String
  revenue             Decimal   @db.Decimal(20, 2)
  profit80            Decimal   @db.Decimal(20, 2)
  profit20            Decimal   @db.Decimal(20, 2)
  barcode             Decimal   @db.Decimal(20, 2)
  cost                Decimal   @db.Decimal(20, 2)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  kukuluban           Decimal?  @default(0) @db.Decimal(20, 2)
  serviceCharge       Decimal?  @default(0) @db.Decimal(20, 2)
  tabungan            Decimal?  @default(0) @db.Decimal(20, 2)
  noteNumber          String?
  notes               String?
  items               Json?     @default("[]")
  deductionDate       DateTime?
  deductionNoteNumber String?
  isValidated         Boolean   @default(false)
  supplier            Supplier  @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([date])
  @@index([supplierId, date])
  @@index([supplierId, tabungan])
  @@index([supplierId, isValidated])
}

model User {
  id                   String    @id @default(cuid())
  username             String    @unique
  password             String
  name                 String?
  role                 String    @default("ADMIN")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  supplierId           String?
  isCredentialsChanged Boolean   @default(false)
  permissions          Json?     @default("[]")
  supplier             Supplier? @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
}

model Product {
  id         String    @id @default(cuid())
  name       String
  code       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  @@unique([name, supplierId])
}

model MaintenanceSetting {
  id              String    @id @default("singleton")
  enabled         Boolean   @default(false)
  message         String    @default("System is under maintenance.")
  estimatedFinish DateTime?
  updatedBy       String    @default("SYSTEM")
  updatedAt       DateTime  @updatedAt
}

model MaintenanceLog {
  id             String    @id @default(cuid())
  action         String
  enabled        Boolean
  message        String
  eta            DateTime?
  telegramUserId String?
  timestamp      DateTime  @default(now())
}

